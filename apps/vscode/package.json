{
  "name": "callimachus-vscode",
  "displayName": "Callimachus — AI history search",
  "description": "Search your AI coding-agent conversation history (Claude Code, Codex, Cursor, Gemini, and 7 more) from VS Code or Cursor — without leaving the editor.",
  "version": "0.1.0",
  "private": true,
  "publisher": "betabots",
  "license": "AGPL-3.0-or-later",
  "icon": "icon.png",
  "homepage": "https://github.com/BetaBots-LLC/callimachus#readme",
  "repository": { "type": "git", "url": "https://github.com/BetaBots-LLC/callimachus.git", "directory": "apps/vscode" },
  "bugs": { "url": "https://github.com/BetaBots-LLC/callimachus/issues" },
  "keywords": ["ai", "claude code", "codex", "cursor", "history", "search", "chatgpt", "copilot"],
  "galleryBanner": { "color": "#C16E2C", "theme": "dark" },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other", "Machine Learning"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "callimachus.search", "title": "Search History", "category": "Callimachus", "icon": "$(search)" },
      { "command": "callimachus.searchCurrentProject", "title": "Search History (current project)", "category": "Callimachus" },
      { "command": "callimachus.searchSelection", "title": "Search History for Selection", "category": "Callimachus" },
      { "command": "callimachus.recent", "title": "Recent Threads", "category": "Callimachus" },
      { "command": "callimachus.insertThread", "title": "Insert Thread into Editor", "category": "Callimachus" },
      { "command": "callimachus.copyThread", "title": "Copy Thread Context", "category": "Callimachus" },
      { "command": "callimachus.refreshRecent", "title": "Refresh", "category": "Callimachus", "icon": "$(refresh)" }
    ],
    "views": {
      "explorer": [
        { "id": "callimachus.recent", "name": "Callimachus History", "icon": "$(history)" }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "callimachus.refreshRecent", "when": "view == callimachus.recent", "group": "navigation" },
        { "command": "callimachus.search", "when": "view == callimachus.recent", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "callimachus.insertThread", "when": "view == callimachus.recent && viewItem == thread", "group": "inline" },
        { "command": "callimachus.copyThread", "when": "view == callimachus.recent && viewItem == thread" }
      ]
    },
    "configuration": {
      "title": "Callimachus",
      "properties": {
        "callimachus.calPath": {
          "type": "string",
          "default": "cal",
          "description": "Path to the Callimachus `cal` CLI binary. Leave as `cal` if it is on your PATH."
        },
        "callimachus.resultLimit": {
          "type": "number",
          "default": 40,
          "description": "Maximum number of results to fetch per search."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "typecheck": "tsc --noEmit -p ./",
    "clean": "rm -rf dist",
    "vscode:prepublish": "pnpm run build",
    "package": "vsce package --no-dependencies -o callimachus-vscode.vsix",
    "publish:vsce": "vsce publish --packagePath callimachus-vscode.vsix",
    "publish:ovsx": "ovsx publish callimachus-vscode.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "ovsx": "^0.10.1",
    "typescript": "~5.8.3"
  }
}
