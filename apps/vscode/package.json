{
  "name": "callimachus-vscode",
  "displayName": "Callimachus — AI history search",
  "description": "Search your AI coding-agent conversation history (Claude Code, Codex, Cursor, Gemini, and 7 more) from VS Code or Cursor — without leaving the editor.",
  "version": "0.9.0",
  "private": true,
  "publisher": "BetaBotsLLC",
  "license": "AGPL-3.0-or-later",
  "icon": "icon.png",
  "homepage": "https://github.com/BetaBots-LLC/callimachus#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/BetaBots-LLC/callimachus.git",
    "directory": "apps/vscode"
  },
  "bugs": {
    "url": "https://github.com/BetaBots-LLC/callimachus/issues"
  },
  "keywords": [
    "ai",
    "claude code",
    "codex",
    "cursor",
    "history",
    "search",
    "chatgpt",
    "copilot"
  ],
  "galleryBanner": {
    "color": "#C16E2C",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "callimachus.search",
        "title": "Search History",
        "category": "Callimachus",
        "icon": "$(search)"
      },
      {
        "command": "callimachus.searchCurrentProject",
        "title": "Search History (current project)",
        "category": "Callimachus"
      },
      {
        "command": "callimachus.searchSelection",
        "title": "Search History for Selection",
        "category": "Callimachus"
      },
      {
        "command": "callimachus.recent",
        "title": "Recent Threads",
        "category": "Callimachus"
      },
      {
        "command": "callimachus.insertThread",
        "title": "Insert Thread into Editor",
        "category": "Callimachus"
      },
      {
        "command": "callimachus.copyThread",
        "title": "Copy Thread Context",
        "category": "Callimachus"
      },
      {
        "command": "callimachus.refreshRecent",
        "title": "Refresh",
        "category": "Callimachus",
        "icon": "$(refresh)"
      },
      {
        "command": "callimachus.toggleAmbientRecall",
        "title": "Toggle Ambient Recall",
        "category": "Callimachus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "callimachus",
          "title": "Callimachus",
          "icon": "media/callimachus.svg"
        }
      ]
    },
    "views": {
      "callimachus": [
        {
          "id": "callimachus.sidebar",
          "name": "History",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "callimachus.refreshRecent",
          "when": "view == callimachus.sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Callimachus",
      "properties": {
        "callimachus.calPath": {
          "type": "string",
          "default": "cal",
          "description": "Path to the Callimachus `cal` CLI binary. Leave as `cal` if it is on your PATH."
        },
        "callimachus.resultLimit": {
          "type": "number",
          "default": 40,
          "description": "Maximum number of results to fetch per search."
        },
        "callimachus.vaultPath": {
          "type": "string",
          "default": "",
          "description": "Obsidian vault folder for the Export action. When empty, Export opens the note as an untitled document instead of writing to a vault."
        },
        "callimachus.openCommand": {
          "type": "string",
          "default": "claude",
          "description": "CLI agent the \"Open in CLI\" action seeds with a thread's context (e.g. `claude`, `codex`, `gemini`). Must be on your PATH."
        },
        "callimachus.ambientRecall": {
          "type": "boolean",
          "default": true,
          "description": "Ambient recall: surface past threads related to whatever you're looking at (selection, symbol, or error) in the Callimachus sidebar, with no searching."
        },
        "callimachus.ambientRecallThrottle": {
          "type": "number",
          "default": 500,
          "description": "Milliseconds to wait after the cursor/selection settles before querying for related threads."
        },
        "callimachus.ambientRecallMinContext": {
          "type": "number",
          "default": 10,
          "description": "Minimum length of the editor context (selection or symbol) before ambient recall runs."
        },
        "callimachus.ambientRecallLimit": {
          "type": "number",
          "default": 5,
          "description": "Maximum related threads to show in the ambient-recall section."
        }
      }
    }
  },
  "scripts": {
    "build:host": "tsc -p ./",
    "build:webview": "vite build --config vite.webview.config.ts",
    "build": "pnpm run build:host && pnpm run build:webview",
    "watch:host": "tsc -w -p ./",
    "watch:webview": "vite build --watch --config vite.webview.config.ts",
    "watch": "pnpm run watch:webview & pnpm run watch:host",
    "typecheck": "tsc --noEmit -p ./ && tsc --noEmit -p tsconfig.webview.json",
    "clean": "rm -rf dist media/webview.js media/webview.css media/assets",
    "vscode:prepublish": "pnpm run build",
    "package": "vsce package --no-dependencies -o callimachus-vscode.vsix",
    "publish:vsce": "vsce publish --packagePath callimachus-vscode.vsix",
    "publish:ovsx": "ovsx publish callimachus-vscode.vsix"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^20.11.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vscode/vsce": "^3.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "ovsx": "^0.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "vite": "^8.0.16"
  }
}
